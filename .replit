entrypoint = "app.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "python app.py"]

autoRun = true

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "requirements.txt"]

[languages.python3]
pattern = "**/*.py"
syntax = "python"
